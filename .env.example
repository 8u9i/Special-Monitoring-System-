# Auth credentials (REQUIRED for login)
AUTH_USER="your_username"
AUTH_PASS="your_password"

# Cookie signing secret (auto-generated if not set, but set explicitly for multi-instance)
COOKIE_SECRET="change-me-to-a-random-string"

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/hadith_tracker"

# Allowed hosts for SSR (comma-separated)
ALLOWED_HOSTS=""

# Server port
PORT=4000

# Node environment
NODE_ENV="production"
